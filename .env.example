# =============================================================================
# MiBici Sonora — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno.
#
#   cp .env.example .env
#
# NUNCA subas el archivo .env al repositorio (está en .gitignore).
# =============================================================================

# ---- Base de datos PostgreSQL/PostGIS ----
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://mibici:mibici_dev@postgres:5432/mibici_sonora

# ---- GBFS MiBici Guadalajara ----
# URL base del feed GBFS v3.0
GBFS_BASE_URL=https://guadalajara.publicbikesystem.net/customer/gbfs/v3.0

# ---- Intervalos de Polling ----
# Cada cuántos segundos se consulta station_status (datos dinámicos)
STATUS_POLL_SECONDS=30

# Cada cuántos segundos se consulta station_information (datos estáticos)
# 14400 = 4 horas
INFO_POLL_SECONDS=14400

# ---- Zona horaria ----
# Los timestamps del GBFS llegan en UTC.
# Esta variable define la zona horaria local para logs y análisis.
TIMEZONE=America/Mexico_City
