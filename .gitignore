# =============================================================================
# MiBici Sonora — .gitignore
# =============================================================================
# Archivos y directorios que NO deben entrar al repositorio.
# Organizado por categoría para facilidad de mantenimiento.
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ---- Entornos virtuales ----
venv/
.venv/
env/

# ---- Variables de entorno (NUNCA subir credenciales) ----
.env
.env.local
.env.production

# ---- Docker ----
# Los volúmenes de datos de PostgreSQL se manejan por Docker, no por git
pgdata/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Sistema operativo ----
.DS_Store
Thumbs.db

# ---- Logs ----
*.log

# ---- Node (para frontend futuro) ----
node_modules/
.next/
frontend/package-lock.json
